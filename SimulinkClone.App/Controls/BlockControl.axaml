<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SimulinkClone.App.Controls.BlockControl"
             Width="210"
             Height="190">

  <UserControl.Styles>
    <Style Selector="TextBlock">
      <Setter Property="FontFamily" Value="Segoe UI, Inter, Arial"/>
    </Style>

    <Style Selector="TextBox">
      <Setter Property="Background" Value="#0F141B"/>
      <Setter Property="Foreground" Value="#EAF2FF"/>
      <Setter Property="BorderBrush" Value="#2A3444"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="FontSize" Value="11"/>
    </Style>
  </UserControl.Styles>

  <Grid ColumnDefinitions="22,*,22"
        RowDefinitions="*"
        Background="Transparent">

    <!-- LEFT PORTS -->
    <Grid Grid.Column="0"
          RowDefinitions="*,*"
          VerticalAlignment="Center"
          HorizontalAlignment="Center"
          Background="Transparent">

      <Border Grid.Row="0"
              Width="22"
              Height="22"
              Background="Transparent"
              Margin="0,8,0,8">
        <Border Name="InputPort1"
                Width="12"
                Height="12"
                CornerRadius="6"
                Background="#1B2230"
                BorderBrush="#91A4C3"
                BorderThickness="1.4"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"/>
      </Border>

      <Border Grid.Row="1"
              Width="22"
              Height="22"
              Background="Transparent"
              Margin="0,8,0,8">
        <Border Name="InputPort2"
                Width="12"
                Height="12"
                CornerRadius="6"
                Background="#1B2230"
                BorderBrush="#91A4C3"
                BorderThickness="1.4"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"/>
      </Border>

    </Grid>

    <!-- BODY -->
    <Border Name="Body"
            Grid.Column="1"
            CornerRadius="14"
            Background="#1A1F2A"
            BorderBrush="#3A465A"
            BorderThickness="1.2"
            Padding="0">

      <Grid RowDefinitions="3,Auto,Auto,Auto">

        <!-- accent -->
        <Border Name="AccentBar"
                Grid.Row="0"
                Background="#3B82F6"
                CornerRadius="14,14,0,0"/>

        <!-- header -->
        <Grid Grid.Row="1"
              Margin="12,10,12,6"
              ColumnDefinitions="Auto,*">

            <Border Width="26"
                    Height="26"
                    CornerRadius="8"
                    Background="#111827"
                    BorderBrush="#334155"
                    BorderThickness="1"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Left">

                <Grid>
                    <TextBlock Name="TitleIcon"
                               Text="■"
                               Foreground="#EAF2FF"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               IsVisible="True"/>

                    <Path Name="MonitorIcon"
                          Width="14"
                          Height="14"
                          Stretch="Uniform"
                          Fill="#EAF2FF"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          IsVisible="False"
                          Data="M2,3 L14,3 L14,9 L2,9 Z M6,11 L10,11 L9,13 L7,13 Z"/>
                </Grid>
            </Border>
          <StackPanel Grid.Column="1"
                      Margin="10,0,0,0"
                      Spacing="2">
            <TextBlock Name="TitleText"
                       Text="Block"
                       Foreground="White"
                       FontSize="15"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis"/>

            <TextBlock Name="ParamText"
                       Text=""
                       Foreground="#7F8CA3"
                       FontSize="11"/>
          </StackPanel>
        </Grid>

        <!-- simple param/info box -->
        <Border Name="SimpleParamPanel"
                Grid.Row="2"
                Margin="12,0,12,10"
                Padding="8,6"
                CornerRadius="10"
                Background="#11161F"
                BorderBrush="#2A3444"
                BorderThickness="1"
                IsVisible="True">
          <TextBlock Name="SimpleParamText"
                     Text=""
                     Foreground="#D3DAE6"
                     FontSize="12"
                     TextWrapping="Wrap"/>
        </Border>

        <!-- monitor panel -->
        <Border Name="MonitorPanel"
                Grid.Row="3"
                Margin="12,0,12,12"
                Padding="8"
                CornerRadius="10"
                Background="#11161F"
                BorderBrush="#2A3444"
                BorderThickness="1"
                IsVisible="False">
          <StackPanel Spacing="6">
            <TextBlock Text="Value"
                       Foreground="#D3DAE6"
                       FontSize="11"/>

            <TextBox Name="MonitorInput"
                     Watermark="leave empty = unknown"/>

            <TextBlock Name="MonitorSolvedText"
                       Text=""
                       Foreground="#9DD6A2"
                       FontSize="11"
                       TextWrapping="Wrap"/>
          </StackPanel>
        </Border>

        <!-- kept hidden only so fs won't fail if called -->
        <Border Name="ConstraintPanel"
                Grid.Row="3"
                IsVisible="False"
                Background="Transparent"
                BorderThickness="0"
                Margin="0"/>

      </Grid>
    </Border>

    <!-- RIGHT PORT -->
    <Border Grid.Column="2"
            Width="22"
            Height="22"
            Background="Transparent"
            VerticalAlignment="Center"
            HorizontalAlignment="Center">
      <Border Name="OutputPort"
              Width="12"
              Height="12"
              CornerRadius="6"
              Background="#1B2230"
              BorderBrush="#91A4C3"
              BorderThickness="1.4"
              VerticalAlignment="Center"
              HorizontalAlignment="Center"/>
    </Border>

  </Grid>
</UserControl>